# Server Port
PORT=5001

# MongoDB Connection String
MONGO_URI=mongodb://localhost:27017/todo-app

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Default user password (used by seed script)
USER_PASS=1234

# Google Gemini AI API Key (get one free at https://aistudio.google.com/apikey)
# Required for the AI Todo Generator feature
GEMINI_API_KEY=your_gemini_api_key_here
